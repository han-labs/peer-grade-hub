# Backend
SERVER_PORT=8080
JAVA_TOOL_OPTIONS=-Duser.timezone=Asia/Ho_Chi_Minh

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=
DB_USERNAME=
DB_PASSWORD=

# JWT
JWT_SECRET=change-this-secret-in-real-env
JWT_EXPIRATION_MS=86400000

# File Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=20

# Frontend
VITE_API_BASE_URL=http://localhost:8080/api
