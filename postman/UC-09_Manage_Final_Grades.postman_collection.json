    {
      "name": "8. Publish Grade - Success (Main Flow Step 2)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response indicates success', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data).to.have.property('publishedGroups');",
              "    pm.expect(jsonData.data.publishedGroups).to.be.an('array');",
              "    pm.expect(jsonData.data).to.have.property('totalPublished');",
              "});",
              "",
              "pm.test('Published groups have correct status', function () {",
              "    var jsonData = pm.response.json();",
              "    var groups = jsonData.data.publishedGroups;",
              "    if (groups.length > 0) {",
              "        var group = groups[0];",
              "        pm.expect(group).to.have.property('success', true);",
              "    }",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
