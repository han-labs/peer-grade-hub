        "body": {
          "mode": "raw",
          "raw": "{\n    \"assignmentId\": {{assignmentId}},\n    \"groupIds\": [{{groupId1}}],\n    \"grades\": [\n        {\n            \"groupId\": {{groupId1}},\n            \"score\": 105,\n            \"comment\": \"Invalid score\"\n        }\n    ]\n}"
