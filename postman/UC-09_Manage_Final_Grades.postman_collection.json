{
  "info": {
    "name": "PeerGrade Hub - UC-09 Manage Final Grades",
    "description": "API Collection for UC-09 Manage Final Grades\n\nMain Flow:\n1. Get grading data (GET /api/grades/assignment/{assignmentId})\n2. Publish grades (POST /api/grades/publish)\n3. Toggle Showcase Mode (POST /api/grades/showcase)\n\nAlternate Flows:\n- Save draft (POST /api/grades/draft)\n- Unpublish grade (POST /api/grades/unpublish)\n\nException Flows:\n- Invalid grade format (0-100)\n- Comment exceeds 2000 characters\n- No group selected\n- Group has no submission (Group C)\n- Group has no peer review - warning only (Group D)\n- System error",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/api",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "assignmentId",
      "value": "1",
      "type": "string"
    },
    {
      "key": "groupId1",
      "value": "1",
      "type": "string"
    },
    {
      "key": "groupId2",
      "value": "2",
      "type": "string"
    },
    {
      "key": "groupId3",
      "value": "3",
      "type": "string"
    },
    {
      "key": "groupId4",
      "value": "4",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "1. Login - Lecturer",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response has data', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data).to.have.property('accessToken');",
              "    pm.expect(jsonData.data).to.have.property('userRole', 'LECTURER');",
              "});",
              "",
              "var jsonData = pm.response.json();",
              "if (jsonData.data && jsonData.data.accessToken) {",
              "    pm.collectionVariables.set('accessToken', jsonData.data.accessToken);",
              "    console.log('Access token saved:', jsonData.data.accessToken);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"usernameOrEmail\": \"lecturer01\",\n    \"password\": \"Lecturer@123\",\n    \"rememberMe\": false\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "login"]
        }
      },
      "response": []
    },
    {
      "name": "2. Login - Student",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "var jsonData = pm.response.json();",
              "pm.test('Student should NOT have LECTURER role', function () {",
              "    pm.expect(jsonData.data.userRole).to.not.equal('LECTURER');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"usernameOrEmail\": \"student01\",\n    \"password\": \"Student@123\",\n    \"rememberMe\": false\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "login"]
        }
      },
      "response": []
    },
    {
      "name": "3. Get Grading Data - Main Flow Step 1",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response has grading data', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data).to.have.property('assignmentId');",
              "    pm.expect(jsonData.data).to.have.property('assignmentTitle');",
              "    pm.expect(jsonData.data).to.have.property('groups');",
              "    pm.expect(jsonData.data.groups).to.be.an('array');",
              "});",
              "",
              "pm.test('Each group has required fields', function () {",
              "    var jsonData = pm.response.json();",
              "    var groups = jsonData.data.groups;",
              "    if (groups.length > 0) {",
              "        var group = groups[0];",
              "        pm.expect(group).to.have.property('groupId');",
              "        pm.expect(group).to.have.property('groupName');",
              "        pm.expect(group).to.have.property('hasSubmission');",
              "        pm.expect(group).to.have.property('hasPeerReview');",
              "        pm.expect(group).to.have.property('isPublished');",
              "        pm.expect(group).to.have.property('canPublish');",
              "    }",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/grades/assignment/{{assignmentId}}",
          "host": ["{{baseUrl}}"],
          "path": ["grades", "assignment", "{{assignmentId}}"]
        }
      },
      "response": []
    },
    {
      "name": "4. Save Draft - Alternate Flow 2a",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response indicates draft saved', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data).to.have.property('isPublished', false);",
              "    pm.expect(jsonData.data).to.have.property('message');",
              "    pm.expect(jsonData.data.message).to.include('draft');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"assignmentId\": {{assignmentId}},\n    \"groupId\": {{groupId1}},\n    \"score\": 85.5,\n    \"comment\": \"Good work! Some areas need improvement, but overall solid effort.\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/grades/draft",
          "host": ["{{baseUrl}}"],
          "path": ["grades", "draft"]
        }
      },
      "response": []
    },
